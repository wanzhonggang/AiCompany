# AI Employee Platform Configuration
# Copy this file to .env and fill in your actual values

# Encryption key (generate a secure one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# Or use a passphrase + salt
ENCRYPTION_KEY=
ENCRYPTION_PASSPHRASE=your_secure_passphrase_here
ENCRYPTION_SALT=your_secure_salt_here

# Database configuration (optional, defaults to SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/ai_employees.db

# LLM API Keys (optional - can also be configured via admin UI)
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
